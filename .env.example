# 微信公众号 API 配置
# 复制此文件为 .env 并填写你的凭证
# 或设置系统环境变量

# 微信公众号 AppID
# 获取方式：登录公众号后台 → 设置与开发 → 基本配置
WECHAT_APPID=wx1234567890abcdef

# 微信公众号 AppSecret
# 获取方式：同上，注意保密不要泄露
WECHAT_APPSECRET=your-app-secret-here

# Unsplash API Key（可选，用于图片搜索）
# 获取方式：https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
